{
  "name": "vibeguard",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "vibeguard": "node packages/cli/dist/index.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "tsc --noEmit",
      "vitest run --changed"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
